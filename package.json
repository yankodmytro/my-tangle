{
  "name": "ecommerce-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.1.0",
  "scripts": {
    "dev": "pnpm nx run-many -t serve --projects=store,admin,api --parallel=3",
    "build": "pnpm nx run-many -t build --projects=store,admin,api",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm nx run-many -t lint --projects=store,admin,api,shared-types,validators,ui --parallel=3",
    "lint:fix": "pnpm exec eslint \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\" --fix",
    "storybook": "pnpm nx storybook ui",
    "storybook:build": "pnpm nx build-storybook ui",
    "test": "pnpm nx run-many -t test --projects=store,admin,api,validators,ui --parallel=3",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
