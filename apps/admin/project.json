{
  "name": "admin",
  "sourceRoot": "apps/admin/src",
  "targets": {
    "serve": {
      "command": "pnpm --dir apps/admin dev"
    },
    "build": {
      "command": "pnpm --dir apps/admin build"
    },
    "lint": {
      "command": "pnpm exec eslint \"apps/admin/src/**/*.{ts,tsx}\""
    },
    "test": {
      "command": "pnpm --dir apps/admin test"
    }
  }
}
