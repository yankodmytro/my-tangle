{
  "name": "store",
  "sourceRoot": "apps/store/src",
  "targets": {
    "serve": {
      "command": "pnpm --dir apps/store dev"
    },
    "build": {
      "command": "pnpm --dir apps/store build"
    },
    "lint": {
      "command": "pnpm exec eslint \"apps/store/src/**/*.{ts,tsx}\""
    },
    "test": {
      "command": "pnpm --dir apps/store test"
    }
  }
}
